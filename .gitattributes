* text=auto eol=lf

# Source code
*.cs text eol=lf diff=csharp
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.config text eol=lf

# Visual Studio solution files use CRLF
*.sln text eol=crlf
*.DotSettings text eol=crlf

# Shell / batch
*.sh text eol=lf
*.bash text eol=lf
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.dll binary
*.exe binary
*.snk binary
