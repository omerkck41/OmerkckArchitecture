# =================================================================
# Kck Architecture — Sample Environment Variables
# Copy this file to .env (or set via appsettings.Development.local.json)
# and fill in the values for the providers you enable.
# DO NOT COMMIT populated .env files.
# =================================================================

# ── Persistence / EF Core ────────────────────────────────────────
ConnectionStrings__Default=Server=localhost;Database=kck_sample;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=True

# ── Redis (Caching + TokenBlacklist) ─────────────────────────────
Redis__ConnectionString=localhost:6379,abortConnect=false
Redis__InstanceName=kck-sample:

# ── RabbitMQ (EventBus) ──────────────────────────────────────────
RabbitMq__Host=localhost
RabbitMq__Port=5672
RabbitMq__Username=
RabbitMq__Password=
RabbitMq__VirtualHost=/

# ── Azure Service Bus (alternative EventBus) ─────────────────────
AzureServiceBus__ConnectionString=

# ── MailKit / SMTP ───────────────────────────────────────────────
MailKit__Host=smtp.example.com
MailKit__Port=587
MailKit__UseSsl=true
MailKit__UserName=
MailKit__Password=
MailKit__PoolSize=5

# ── SendGrid ─────────────────────────────────────────────────────
SendGrid__ApiKey=

# ── Amazon SES ───────────────────────────────────────────────────
AmazonSes__AccessKey=
AmazonSes__SecretKey=
AmazonSes__Region=eu-west-1

# ── FluentFTP ────────────────────────────────────────────────────
FluentFtp__Host=
FluentFtp__Port=21
FluentFtp__Username=
FluentFtp__Password=
FluentFtp__UseSsl=false
FluentFtp__PoolSize=5

# ── JWT ──────────────────────────────────────────────────────────
Jwt__Issuer=https://kck.example.com
Jwt__Audience=kck-clients
Jwt__SigningKeyPem=
Jwt__AccessTokenLifetimeMinutes=15
Jwt__RefreshTokenLifetimeDays=7

# ── Elasticsearch ────────────────────────────────────────────────
Elasticsearch__Uri=http://localhost:9200
Elasticsearch__ApiKey=

# ── OpenTelemetry ────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=Kck.Sample.WebApi

# ── Hangfire (if used) ───────────────────────────────────────────
Hangfire__ConnectionString=

# ── Azure Key Vault (Secrets) ────────────────────────────────────
AzureKeyVault__VaultUri=

# ── Runtime ──────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
